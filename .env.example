# Runner
OPENAI_API_KEY="sk-proj-123"
HOST="127.0.0.1"
PORT="4001"
CUA_DEFAULT_MODEL="gpt-5.4"
CUA_RESPONSES_MODE="auto"

# Web
RUNNER_BASE_URL="http://127.0.0.1:4001"
NEXT_PUBLIC_CUA_DEFAULT_MODEL="gpt-5.4"
NEXT_PUBLIC_CUA_DEFAULT_MAX_RESPONSE_TURNS="24"
ENABLE_WEB="false"

# Tool safety
CUA_ALLOW_DANGEROUS_COMMANDS="false"
CUA_ENABLE_DESKTOP_CONTROL="true"

# Telegram control bot (optional but recommended for the new chat-first workflow)
ENABLE_TELEGRAM="true"
TELEGRAM_REQUIRE_ALLOWLIST="true"
TELEGRAM_ALLOW_OPEN_ACCESS="false"
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_RUNNER_BASE_URL=http://127.0.0.1:4001
TELEGRAM_DEFAULT_SCENARIO_ID=desktop-control-console
TELEGRAM_MODEL=gpt-5.4
TELEGRAM_BROWSER_MODE=headless
TELEGRAM_MAX_RESPONSE_TURNS=20
TELEGRAM_MAX_HISTORY_MESSAGES=12
TELEGRAM_SEND_EVENT_SUMMARIES=true

